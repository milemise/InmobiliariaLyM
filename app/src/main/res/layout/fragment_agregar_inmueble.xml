<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80CBC4">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloAgregar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Información del inmueble"
            android:textColor="#C2185B"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/lblDireccionForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Dirección"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tvTituloAgregar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/lblAmbientesForm"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/etDireccion"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="#5C8CBA"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toBottomOf="@id/lblDireccionForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/etAmbientes"/>

        <TextView
            android:id="@+id/lblAmbientesForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ambientes"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="@id/lblDireccionForm"
            app:layout_constraintStart_toEndOf="@id/lblDireccionForm"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etAmbientes"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:inputType="number"
            android:background="#5C8CBA"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            app:layout_constraintTop_toBottomOf="@id/lblAmbientesForm"
            app:layout_constraintStart_toEndOf="@id/etDireccion"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/lblPrecioForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Precio"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/etDireccion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/lblUsoForm"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/etPrecio"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:inputType="numberDecimal"
            android:background="#5C8CBA"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toBottomOf="@id/lblPrecioForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/etUso"/>

        <TextView
            android:id="@+id/lblUsoForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Uso"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="@id/lblPrecioForm"
            app:layout_constraintStart_toEndOf="@id/lblPrecioForm"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etUso"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="#5C8CBA"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            app:layout_constraintTop_toBottomOf="@id/lblUsoForm"
            app:layout_constraintStart_toEndOf="@id/etPrecio"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/lblTipoForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tipo"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/etPrecio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cbDisponibleForm"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/etTipo"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="#5C8CBA"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toBottomOf="@id/lblTipoForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cbDisponibleForm"/>

        <CheckBox
            android:id="@+id/cbDisponibleForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Disponible"
            android:textColor="#FFFFFF"
            android:buttonTint="#FFFFFF"
            android:checked="true"
            app:layout_constraintTop_toTopOf="@id/etTipo"
            app:layout_constraintBottom_toBottomOf="@id/etTipo"
            app:layout_constraintStart_toEndOf="@id/etTipo"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/ivFotoAgregar"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_camera"
            app:layout_constraintTop_toBottomOf="@id/etTipo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="30dp"
            android:background="#E0E0E0"/>

        <Button
            android:id="@+id/btnGuardarInmueble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar Inmueble"
            android:backgroundTint="#C2185B"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/ivFotoAgregar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>